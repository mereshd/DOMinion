{
  "manifest_version": 3,
  "name": "ArticleNotes",
  "version": "0.1.0",
  "description": "AI-powered article annotations — fact-checks, context, and explanations inline.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      // "16": "icons/icon16.png",
      // "48": "icons/icon48.png",
      // "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
